# =============================================================================
# Board Dispatcher — Configuration
# =============================================================================
# Copy this file to config.yaml and adjust paths to your environment:
#   cp config.yaml.example config.yaml
#
# All paths support ~ (home directory expansion).
# =============================================================================

board_dispatcher:
  poll_interval_sec: 10
  artifacts_dir: "./artifacts"
  approval_timeout_hours: 24

  jira:
    # Tickets with this label will be picked up by the dispatcher
    label: "claudio"
    excluded_statuses:
      - Done
      - Closed

  # Default repo used when a ticket has no 'repo:<name>' label
  default_repo: "your-repo"

  # Map of repo names to local paths.
  # The dispatcher creates git worktrees in these repos.
  # You must have these repos cloned locally.
  repos:
    your-repo: "~/path/to/your-repo"
    # another-repo: "~/path/to/another-repo"

  # Plugin loading mode for aiops-workflows.
  # This plugin provides the skills used by agents (ticket-plan, ticket-implement, etc.)
  #
  # "installed" (default) — plugin is already installed in your Claude Code setup.
  #   No extra config needed. Best for developers who use the plugin daily.
  #
  # "local" — plugin is loaded from a local directory path.
  #   Requires plugin_path to be set. Best for evaluators or CI environments
  #   that don't have the plugin installed globally.
  #
  plugin_mode: "installed"
  # plugin_mode: "local"
  # plugin_path: "~/path/to/aiops-claude-code/plugins/aiops-workflows"

  workspace:
    # Directory where git worktrees are created (one per ticket).
    # This can be /tmp or any writable directory.
    root: "/tmp/board-dispatcher-workspaces"

  # Agent profiles — different LLM configs for different tasks
  agents:
    doc_checker:
      model: "sonnet"
      max_turns: 20
      max_budget_usd: 5.0
      tools: ["Read", "Glob", "Grep", "Bash"]

    standard:
      model: "sonnet"
      max_turns: 200
      max_budget_usd: 50.0

    heavy:
      model: "opus"
      max_turns: 500
      max_budget_usd: 50.0

  retry:
    max_retries: 3
    base_delay_sec: 10
    max_backoff_sec: 300
