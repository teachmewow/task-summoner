# =============================================================================
# Task Summoner — Configuration
# =============================================================================
# Copy this file to config.yaml and adjust to your environment:
#   cp config.yaml.example config.yaml
#
# Or run the interactive wizard:
#   task-summoner setup
#
# All paths support ~ (home directory expansion).
# Use ${VAR_NAME} to reference environment variables (read from .env or shell).
# =============================================================================

providers:
  board:
    type: linear          # linear | jira

    # If type = linear, fill this block:
    linear:
      api_key: ${LINEAR_API_KEY}
      team_id: "your-team-id-uuid"
      watch_label: task-summoner

    # If type = jira, fill this block instead:
    # jira:
    #   email: ${ATLASSIAN_EMAIL}
    #   token: ${ATLASSIAN_TOKEN}
    #   watch_label: task-summoner

  agent:
    type: claude_code     # claude_code | codex

    claude_code:
      # auth_method: personal_session — inherit your logged-in Claude Code
      #   session (recommended; no API key needed). Requires `claude login`.
      # auth_method: api_key          — pass an explicit Anthropic API key.
      auth_method: personal_session
      # api_key: ${ANTHROPIC_API_KEY}  # only needed when auth_method: api_key

      # plugin_mode: installed — plugin comes from your Claude Code setup.
      # plugin_mode: local    — load from plugin_path (for CI or evaluators).
      plugin_mode: installed
      # plugin_path: ~/path/to/task-summoner-plugin/plugins/tmw-workflows

    # If type = codex, fill this block instead:
    # codex:
    #   api_key: ${OPENAI_API_KEY}

# -----------------------------------------------------------------------------
# Repos that task-summoner can operate on. The dispatcher creates git worktrees
# in these repos; they must be cloned locally.
# -----------------------------------------------------------------------------
repos:
  your-repo: ~/code/your-repo
  # another-repo: ~/code/another-repo

# Fallback when a ticket has no `repo:<name>` label.
default_repo: your-repo

# -----------------------------------------------------------------------------
# Agent profiles — mapped to lifecycle phases by the state handlers.
# -----------------------------------------------------------------------------
agent_profiles:
  doc_checker:
    model: haiku
    max_turns: 20
    max_budget_usd: 5
    tools: [Read, Glob, Grep, Bash]

  standard:
    model: sonnet
    max_turns: 200
    max_budget_usd: 50

  heavy:
    model: opus
    max_turns: 500
    max_budget_usd: 50

# -----------------------------------------------------------------------------
# Polling & workspace
# -----------------------------------------------------------------------------
polling_interval_sec: 10
workspace_root: /tmp/task-summoner-workspaces
artifacts_dir: ./artifacts
approval_timeout_hours: 24

retry:
  max_retries: 3
  base_delay_sec: 10
  max_backoff_sec: 300

# -----------------------------------------------------------------------------
# Cost & Usage (optional)
# -----------------------------------------------------------------------------
# monthly_budget_usd: 50.0   # surfaces as burndown on /cost (unset = unlimited)
